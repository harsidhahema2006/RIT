# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/smart_power_distribution
MONGODB_TEST_URI=mongodb://localhost:27017/smart_power_distribution_test

# Python Microservice Configuration
PYTHON_ML_SERVICE_URL=http://localhost:8000
PYTHON_RL_SERVICE_URL=http://localhost:8001
ML_SERVICE_URL=http://localhost:8000
ML_SERVICE_TIMEOUT=10000

# Security
JWT_SECRET=your_jwt_secret_key_here
API_RATE_LIMIT=100

# Simulation Configuration
SIMULATION_INTERVAL=5000
LOAD_UPDATE_VARIANCE=0.15
PREDICTION_HORIZON=24

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log